---
layout: default
---
{% assign category = page.category %}
{% assign social = page.profile.social %}
<div class="post">

    <header class="post-header">
        <h1 class="post-title">
            It's me, <span class="font-weight-bold">Kevin</span> <span class="text-muted">- {{ category }} -</span>
        </h1>

        {% if social.instagram %}
            <a href="https://instagram.com/{{ social.instagram }}">
                <i class="fab fa-instagram"></i>
            </a>
        {% endif %}
        {% if social.youtube %}
            <a href="https://www.youtube.com/@{{ social.youtube }}">
                <i class="fab fa-youtube"></i>
            </a>
        {% endif %}
        {% if social.github %}
            <a href="https://github.com/{{ social.github }}">
                <i class="fab fa-github"></i>
            </a>
        {% endif %}
    </header>

    <hr>

    {% include tag_category_list.liquid category=page.category %}

    {% include featured_posts/all.liquid category=page.category%}

    {% include posts/all.liquid category=page.category %}

</div>